# =============================================================================
# Cognee + VectraDB Full Stack Configuration
# =============================================================================
# Copy this file to .env and fill in the required values:
#   cp .env.template .env
# =============================================================================

# --- LLM Configuration (REQUIRED — at least one provider) ---
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=openai/gpt-4o-mini
LLM_PROVIDER=openai
# LLM_ENDPOINT=                    # Override for Azure/Ollama/custom
# LLM_API_VERSION=                 # Azure OpenAI API version

# --- Embedding Configuration ---
EMBEDDING_MODEL=openai/text-embedding-3-large
EMBEDDING_PROVIDER=openai
# EMBEDDING_ENDPOINT=              # Override for Ollama/custom
# EMBEDDING_DIMENSIONS=            # Must match model output (e.g. 3072, 1536, 1024)
# HUGGINGFACE_TOKENIZER=           # Required for Ollama embeddings

# --- PostgreSQL ---
POSTGRES_USER=cognee
POSTGRES_PASSWORD=cognee
POSTGRES_DB=cognee_db

# --- Neo4j ---
NEO4J_PASSWORD=pleaseletmein

# --- VectraDB ---
# Vector dimension MUST match your embedding model output:
#   text-embedding-3-large = 3072 (but Cognee truncates to 1536 by default)
#   text-embedding-3-small = 1536
#   text-embedding-ada-002 = 1536
VECTRADB_DIM=1536
VECTRADB_SHARDS=3
VECTOR_DB_KEY=

# --- Redis ---
# No additional config needed for default setup

# --- Server ---
CORS_ALLOWED_ORIGINS=*

# --- Security ---
REQUIRE_AUTHENTICATION=false
# COGNEE_API_TOKEN=your_api_token_here   # For MCP→API and Git Hook→API auth
# AUTH_TOKEN_COOKIE_NAME=auth_token

# --- Security (production overrides) ---
# ACCEPT_LOCAL_FILE_PATH=false
# ALLOW_HTTP_REQUESTS=false
# ALLOW_CYPHER_QUERY=false
# REQUIRE_AUTHENTICATION=true
# ENABLE_BACKEND_ACCESS_CONTROL=true

# --- Rate Limiting ---
LLM_RATE_LIMIT_ENABLED=true
LLM_RATE_LIMIT_REQUESTS=60
LLM_RATE_LIMIT_INTERVAL=60

# --- Storage Backend ---
# STORAGE_BACKEND=local              # local (default) or s3
# STORAGE_BUCKET_NAME=               # S3 bucket name
# DATA_ROOT_DIRECTORY=               # Override data root
# SYSTEM_ROOT_DIRECTORY=             # Override system root

# --- Monitoring (optional) ---
# SENTRY_REPORTING_URL=
# LITELLM_LOG=ERROR                  # Set to DEBUG for verbose LLM logs
# TELEMETRY_DISABLED=1               # Disable built-in telemetry

# --- Git Hook ---
# COGNEE_API_URL=http://localhost:8000
# COGNEE_DATASET=git_repo

# =============================================================================
# EXAMPLE: llama.cpp + embed-server on GPU server
# =============================================================================
# LLM_API_KEY=no-key
# LLM_MODEL=qwen
# LLM_PROVIDER=llama_cpp
# LLM_ENDPOINT=http://10.23.0.64:9004/v1
#
# EMBEDDING_MODEL=openai/pplx
# EMBEDDING_PROVIDER=openai
# EMBEDDING_ENDPOINT=http://10.23.0.64:9001/v1
# EMBEDDING_DIMENSIONS=1024
#
# VECTRADB_DIM=1024
