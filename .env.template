# Levara local configuration template.
#
# Copy to `.env` for local Docker/dev scripts. Keep real credentials out of git.
# Audience-specific presets live in `Levara/deploy/profiles/*.env.example`.

# Runtime profile:
#   personal   - local SQLite/files, auth optional
#   solo_pro   - local + sync/backups
#   team       - Postgres + required auth
#   enterprise - strict tenant/audit/auth checks
LEVARA_PROFILE=personal
LEVARA_PROFILE_STRICT=0

# Server
ENV=dev
LEVARA_DIM=1024
LEVARA_SHARDS=3
REQUIRE_AUTH=false
JWT_SECRET=

# Storage
DB_PROVIDER=sqlite
DB_PATH=./Levara/data/levara.db
POSTGRES_USER=levara
POSTGRES_PASSWORD=change-me
POSTGRES_DB=levara_db
POSTGRES_DSN=

# Embeddings
EMBEDDING_ENDPOINT=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1024

# LLM / cognify
LLM_PROVIDER=
LLM_ENDPOINT=
LLM_MODEL=
LLM_API_KEY=
LLM_RATE_LIMIT_REQUESTS=60
LLM_RATE_LIMIT_INTERVAL=60

# Workspace and audit
LEVARA_WORKSPACE_WATCH=1
LEVARA_WORKSPACE_INDEX_WORKER=1
LEVARA_WORKSPACE_AUDIT_EXPORT=0
LEVARA_WORKSPACE_AUDIT_EXPORT_DIR=./Levara/data/audit/workspace
LEVARA_WORKSPACE_AUDIT_RETENTION_DAYS=30

# Sync / Solo Pro
LEVARA_TOKEN=
LEVARA_SYNC_REMOTE_URL=

# Object storage
STORAGE_BACKEND=local
STORAGE_PATH=./Levara/data/storage
STORAGE_BUCKET_NAME=

# Security posture
LEVARA_TENANT_ENFORCED=0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
