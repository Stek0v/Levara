# Local Mac — native PostgreSQL metadata (personal/solo_pro with SQL parity to qwen-64)
# Copy to .env.postgres.local (gitignored) or export before start-levara.sh

LEVARA_POSTGRES_MODE=native
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_NAME=levara
DATABASE_URL=

POSTGRES_HOST=localhost
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=levara
POSTGRES_PORT=5432
LEVARA_POSTGRES_BREW_SERVICE=postgresql@16

# Dev/bench: auth is not the thing under test — lift the 10/min IP cap on register+login.
RATE_LIMIT_AUTH_MAX=10000
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
