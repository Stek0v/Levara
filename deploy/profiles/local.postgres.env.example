# Local Mac — PostgreSQL metadata (personal/solo_pro with SQL parity to qwen-64)
# Copy to .env.postgres.local (gitignored) or export before start-levara.sh

DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=levara
DB_PASSWORD=levara
DB_NAME=levara

POSTGRES_USER=levara
POSTGRES_PASSWORD=levara
POSTGRES_DB=levara
POSTGRES_PORT=5433

# Dev/bench: auth is not the thing under test — lift the 10/min IP cap on register+login.
RATE_LIMIT_AUTH_MAX=10000
RATE_LIMIT_AUTH_WINDOW_SECONDS=60
