# Levara Team profile
# Audience: a small team with humans and AI agents sharing project workspaces.

LEVARA_PROFILE=team
LEVARA_PROFILE_STRICT=1

DB_PROVIDER=postgres
POSTGRES_DSN=postgres://levara:change-me@localhost:5432/levara?sslmode=disable

# Team profile requires stable auth. Start the server with -require-auth.
JWT_SECRET=replace-with-stable-random-secret

# Workspace jobs and audit are expected in shared team deployments.
LEVARA_WORKSPACE_WATCH=1
LEVARA_WORKSPACE_INDEX_WORKER=1
LEVARA_WORKSPACE_AUDIT_EXPORT=1
LEVARA_WORKSPACE_AUDIT_EXPORT_DIR=./data/audit/workspace
LEVARA_WORKSPACE_AUDIT_RETENTION_DAYS=30

# Tenant enforcement is optional for Team but required for Enterprise.
LEVARA_TENANT_ENFORCED=0
