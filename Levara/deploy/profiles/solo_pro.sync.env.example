# Levara Solo Pro profile
# Audience: one power user syncing several machines, for example Mac <-> Pi.

LEVARA_PROFILE=solo_pro
DB_PROVIDER=sqlite
DB_PATH=./data/levara.db

# Sync must use a stable bearer token. Do not rotate this casually between
# machines or scheduled sync jobs will fail.
LEVARA_TOKEN=replace-with-stable-sync-token
LEVARA_SYNC_REMOTE_URL=http://10.23.0.53:8090/api/v1

# Optional object storage. Leave local for a single-machine setup.
STORAGE_BACKEND=local
STORAGE_PATH=./data/storage

LEVARA_WORKSPACE_WATCH=1
LEVARA_WORKSPACE_INDEX_WORKER=1
