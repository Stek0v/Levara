# Levara Personal / Local profile
# Audience: one developer with local AI agents.

LEVARA_PROFILE=personal
DB_PROVIDER=sqlite
DB_PATH=./data/levara.db

# Local workspace + MCP are the default operating mode.
LEVARA_WORKSPACE_WATCH=1
LEVARA_WORKSPACE_INDEX_WORKER=1

# Auth is optional for personal local use. Leave -require-auth off unless the
# local port is reachable by other users.
JWT_SECRET=

# Optional local embedding service. Lexical workspace search still works when
# no embedder is configured.
EMBEDDING_ENDPOINT=
EMBEDDING_MODEL=
