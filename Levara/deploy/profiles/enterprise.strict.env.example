# Levara Enterprise strict profile
# Audience: corporate teams with central identity, tenant isolation, audit, and
# future corporate storage/KMS adapters.

LEVARA_PROFILE=enterprise
LEVARA_PROFILE_STRICT=1

DB_PROVIDER=postgres
POSTGRES_DSN=postgres://levara:change-me@localhost:5432/levara?sslmode=require

# Enterprise requires required auth or a configured SSO bridge. JWT_SECRET still
# needs to be stable for local tokens/session signing unless the deployment
# replaces that path with a verified SSO bridge.
JWT_SECRET=replace-with-stable-random-secret
LEVARA_SSO_BRIDGE=local-or-enterprise-bridge

LEVARA_TENANT_ENFORCED=1

LEVARA_WORKSPACE_AUDIT_EXPORT=1
LEVARA_WORKSPACE_AUDIT_EXPORT_DIR=/var/log/levara/workspace-audit
LEVARA_WORKSPACE_AUDIT_RETENTION_DAYS=90

# Storage/KMS/BYOK are still adapter work, not production-ready guarantees.
STORAGE_BACKEND=local
STORAGE_PATH=/var/lib/levara/storage
