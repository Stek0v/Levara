# Levara Environment Configuration for Raspberry Pi
# Copy to /etc/levara/levara.env

# --- Storage ---
DB_PROVIDER=sqlite
DB_PATH=/var/lib/levara/levara.db

# --- Embedding ---
# potion-code-16M (256d, model2vec) via co-located sidecar on loopback :9101.
# Provisioned by embed-potion.service; -dim=256 in the unit MUST match.
EMBEDDING_ENDPOINT=http://localhost:9101/v1/embeddings
EMBEDDING_MODEL=potion-code-16M
# Legacy nomic (768d, decommissioned 2026-06-04) — restore -dim=768 if reverting:
# EMBEDDING_ENDPOINT=http://localhost:11434/v1/embeddings
# EMBEDDING_MODEL=nomic-embed-text-v2-moe

# --- LLM ---
LLM_PROVIDER=openai
LLM_ENDPOINT=http://localhost:11434/v1
LLM_MODEL=gemma3:4b
# For Pi 4GB, use: LLM_MODEL=qwen2:0.5b
LLM_TIMEOUT=120

# --- Rate Limiting (important for Pi!) ---
LLM_RATE_LIMIT_REQUESTS=10
LLM_RATE_LIMIT_INTERVAL=60

# --- Cache ---
CACHE_TTL=7200
CACHE_MAX_SIZE=500

# --- Logging ---
LOG_LEVEL=INFO

# --- Optional: Remote LLM (offload to a more powerful machine) ---
# LLM_ENDPOINT=http://your-server:11434/v1
# LLM_MODEL=qwen3.5
# LLM_RATE_LIMIT_REQUESTS=60
