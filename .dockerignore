webui/node_modules
webui/.next
webui/test-results
webui/playwright-report
node_modules
coverage

# Local model weights and downloadable artifacts.
models
*.gguf
*.onnx
*.safetensors
*.tar
*.tar.gz
*.zip

# Local secrets must never enter the build context.
.env
.env.*
!.env.example
!*.env.example
